# Demonstrating basic data types

define number = 42;
define float = 3.14;
define text = "Starlight";
define boolean = true;
define empty = null;

sldeploy("Number:");
sldeploy number;

sldeploy("Float:");
sldeploy float;

sldeploy("Text:");
sldeploy text;

sldeploy("Boolean:");
sldeploy boolean;

sldeploy("Null:");
sldeploy empty;
